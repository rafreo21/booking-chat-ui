# --- Easiest: Google Apps Script (no service account) ---
# Paste scripts/google-apps-script/booking-append.gs into the spreadsheet’s Apps Script,
# deploy as Web app (Anyone), then set:
GOOGLE_APPS_SCRIPT_URL=
# Optional; if set, add same value as Script property BOOKING_SECRET in Apps Script.
GOOGLE_APPS_SCRIPT_SECRET=

# --- Alternative: Google Sheets API + service account ---
# GOOGLE_SERVICE_ACCOUNT_JSON=
# Optional override (defaults to the booking-chat-ui sheet in the repo):
# GOOGLE_SHEET_ID=
# GOOGLE_SHEET_RANGE=Sheet1!A:I

# Optional: require Authorization: Bearer … from the browser (set VITE_BOOKING_INGEST_SECRET too).
# BOOKING_INGEST_SECRET=
# VITE_BOOKING_INGEST_SECRET=

# Local dev without vercel dev: point at production API.
# VITE_SHEETS_APPEND_URL=https://your-project.vercel.app/api/sheets-append
